digraph random_forest {
    rankdir=TB;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.2];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.2, color="#555555"];
    nodesep=0.4;
    ranksep=0.6;
    pad=0.4;

    // Title
    title [label="Random Forest Classifier", shape=plaintext, fillcolor=white,
           fontsize=14, fontcolor="#1565C0"];

    // Input
    input [label="Input Feature Vector\n(78–276 features depending on model)",
           fillcolor="#E3F2FD", color="#1565C0", width=3.5];

    // Bootstrap samples
    subgraph cluster_bootstrap {
        label="Bootstrap Sampling";
        labeljust=c;
        fontsize=9;
        color="#90CAF9";
        style="dashed,rounded";
        margin=12;
        bgcolor="#F5F9FF";

        bs1 [label="Sample 1\n(with replacement)", fillcolor="#BBDEFB", color="#1565C0", width=1.8];
        bs2 [label="Sample 2\n(with replacement)", fillcolor="#BBDEFB", color="#1565C0", width=1.8];
        bsdots [label="· · ·", shape=plaintext, fillcolor=white, fontsize=14];
        bs100 [label="Sample 100\n(with replacement)", fillcolor="#BBDEFB", color="#1565C0", width=1.8];
    }

    // Decision trees
    subgraph cluster_trees {
        label="100 Decision Trees  (max depth = 20, min samples split = 5)";
        labeljust=c;
        fontsize=9;
        color="#81C784";
        style="dashed,rounded";
        margin=12;
        bgcolor="#F1F8F1";

        t1 [label="Tree 1\n🌲", fillcolor="#C8E6C9", color="#2E7D32", width=1.4];
        t2 [label="Tree 2\n🌲", fillcolor="#C8E6C9", color="#2E7D32", width=1.4];
        tdots [label="· · ·", shape=plaintext, fillcolor=white, fontsize=14];
        t100 [label="Tree 100\n🌲", fillcolor="#C8E6C9", color="#2E7D32", width=1.4];
    }

    // Predictions
    p1 [label="Class: DoS", fillcolor="#FFF3E0", color="#E65100", width=1.4];
    p2 [label="Class: Normal", fillcolor="#FFF3E0", color="#E65100", width=1.4];
    pdots [label="· · ·", shape=plaintext, fillcolor=white, fontsize=14];
    p100 [label="Class: Probe", fillcolor="#FFF3E0", color="#E65100", width=1.4];

    // Voting
    voting [label="Majority Voting\n(hard vote across 100 predictions)",
            fillcolor="#FFE0B2", color="#E65100", width=3.5];

    // Output
    output [label="Final Prediction\nNormal | DoS | Probe | R2L | U2R",
            fillcolor="#FFCDD2", color="#C62828", width=3.5];

    // Layout
    title -> input [style=invis];

    input -> bs1;
    input -> bs2;
    input -> bsdots [style=invis];
    input -> bs100;

    bs1 -> t1;
    bs2 -> t2;
    bsdots -> tdots [style=invis];
    bs100 -> t100;

    t1 -> p1;
    t2 -> p2;
    tdots -> pdots [style=invis];
    t100 -> p100;

    p1 -> voting;
    p2 -> voting;
    pdots -> voting [style=invis];
    p100 -> voting;

    voting -> output;

    // Align nodes in same ranks
    {rank=same; bs1; bs2; bsdots; bs100;}
    {rank=same; t1; t2; tdots; t100;}
    {rank=same; p1; p2; pdots; p100;}
}
