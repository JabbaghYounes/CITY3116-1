digraph cnn_lstm {
    rankdir=TB;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.2];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.2, color="#555555"];
    nodesep=0.5;
    ranksep=0.55;
    pad=0.4;

    // Title
    title [label="CNN+LSTM Network  (~297K parameters)", shape=plaintext, fillcolor=white,
           fontsize=14, fontcolor="#1565C0"];

    // Input
    input [label="Input Feature Vector\n(1 × N features, reshaped as 1-channel sequence)",
           fillcolor="#E3F2FD", color="#1565C0", width=4.5];

    // Conv Block 1
    subgraph cluster_conv1 {
        label="Convolutional Block 1";
        labeljust=c;
        fontsize=9;
        color="#7986CB";
        style="rounded";
        margin=12;
        bgcolor="#EDE7F6";

        conv1 [label="Conv1d\n1 → 64 filters, kernel=3", fillcolor="#D1C4E9", color="#4527A0", width=3.2];
        bn1 [label="Batch Normalisation", fillcolor="#D1C4E9", color="#4527A0", width=2.4];
        relu1 [label="ReLU Activation", fillcolor="#D1C4E9", color="#4527A0", width=2.0];
    }

    // Conv Block 2
    subgraph cluster_conv2 {
        label="Convolutional Block 2";
        labeljust=c;
        fontsize=9;
        color="#7986CB";
        style="rounded";
        margin=12;
        bgcolor="#EDE7F6";

        conv2 [label="Conv1d\n64 → 128 filters, kernel=3", fillcolor="#D1C4E9", color="#4527A0", width=3.2];
        bn2 [label="Batch Normalisation", fillcolor="#D1C4E9", color="#4527A0", width=2.4];
        relu2 [label="ReLU Activation", fillcolor="#D1C4E9", color="#4527A0", width=2.0];
    }

    // LSTM
    subgraph cluster_lstm {
        label="Sequence Modelling";
        labeljust=c;
        fontsize=9;
        color="#2E7D32";
        style="rounded";
        margin=12;
        bgcolor="#F1F8F1";

        lstm [label="LSTM\n128 hidden units, 2 layers\ndropout = 0.3", fillcolor="#C8E6C9", color="#2E7D32", width=3.4];
    }

    // FC layers
    subgraph cluster_fc {
        label="Fully Connected Layers";
        labeljust=c;
        fontsize=9;
        color="#E65100";
        style="rounded";
        margin=12;
        bgcolor="#FFF8F0";

        fc1 [label="Linear  128 → 64\n+ ReLU + Dropout(0.3)", fillcolor="#FFE0B2", color="#E65100", width=3.2];
        fc2 [label="Linear  64 → 5", fillcolor="#FFE0B2", color="#E65100", width=2.0];
    }

    // Output
    softmax [label="Softmax", fillcolor="#FFCDD2", color="#C62828", width=1.6];
    output [label="Prediction\nNormal | DoS | Probe | R2L | U2R",
            fillcolor="#FFCDD2", color="#C62828", width=3.5];

    // Edges
    title -> input [style=invis];
    input -> conv1;
    conv1 -> bn1;
    bn1 -> relu1;
    relu1 -> conv2 [label="  64-channel\n  feature maps", fontcolor="#555555"];
    conv2 -> bn2;
    bn2 -> relu2;
    relu2 -> lstm [label="  128-channel\n  feature maps", fontcolor="#555555"];
    lstm -> fc1 [label="  last hidden\n  state", fontcolor="#555555"];
    fc1 -> fc2;
    fc2 -> softmax;
    softmax -> output;
}
