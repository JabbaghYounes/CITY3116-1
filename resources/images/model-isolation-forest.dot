digraph isolation_forest {
    rankdir=TB;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.2];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.2, color="#555555"];
    nodesep=0.4;
    ranksep=0.6;
    pad=0.4;

    // Title
    title [label="Isolation Forest  (Unsupervised Anomaly Detection)", shape=plaintext, fillcolor=white,
           fontsize=14, fontcolor="#1565C0"];

    // Input
    input [label="Input Feature Vector\n(78–276 features)",
           fillcolor="#E3F2FD", color="#1565C0", width=3.5];

    // Subsampling
    subgraph cluster_subsample {
        label="Random Subsampling";
        labeljust=c;
        fontsize=9;
        color="#90CAF9";
        style="dashed,rounded";
        margin=12;
        bgcolor="#F5F9FF";

        ss1 [label="Subsample 1\n(random features\n+ random split values)", fillcolor="#BBDEFB", color="#1565C0", width=2.2];
        ss2 [label="Subsample 2", fillcolor="#BBDEFB", color="#1565C0", width=1.6];
        ssdots [label="· · ·", shape=plaintext, fillcolor=white, fontsize=14];
        ssN [label="Subsample N", fillcolor="#BBDEFB", color="#1565C0", width=1.6];
    }

    // Isolation Trees
    subgraph cluster_itrees {
        label="Isolation Trees  (random recursive partitioning)";
        labeljust=c;
        fontsize=9;
        color="#81C784";
        style="dashed,rounded";
        margin=12;
        bgcolor="#F1F8F1";

        it1 [label="iTree 1", fillcolor="#C8E6C9", color="#2E7D32", width=1.4];
        it2 [label="iTree 2", fillcolor="#C8E6C9", color="#2E7D32", width=1.4];
        itdots [label="· · ·", shape=plaintext, fillcolor=white, fontsize=14];
        itN [label="iTree N", fillcolor="#C8E6C9", color="#2E7D32", width=1.4];
    }

    // Path lengths
    subgraph cluster_paths {
        label="Path Lengths  (depth to isolate the sample)";
        labeljust=c;
        fontsize=9;
        color="#E65100";
        style="dashed,rounded";
        margin=12;
        bgcolor="#FFF8F0";

        pl1 [label="depth = 3\n(short path)", fillcolor="#FFE0B2", color="#E65100", width=1.6];
        pl2 [label="depth = 11\n(long path)", fillcolor="#FFE0B2", color="#E65100", width=1.6];
        pldots [label="· · ·", shape=plaintext, fillcolor=white, fontsize=14];
        plN [label="depth = 4\n(short path)", fillcolor="#FFE0B2", color="#E65100", width=1.6];
    }

    // Aggregation
    agg [label="Average Path Length\nacross all trees",
         fillcolor="#FFF3E0", color="#E65100", width=3.5];

    // Anomaly score
    score [label="Anomaly Score\ns(x, n) = 2^(-E(h(x)) / c(n))\nscore ≈ 1 → anomaly    score ≈ 0.5 → normal",
           fillcolor="#F3E5F5", color="#6A1B9A", width=4.5];

    // Decision
    subgraph cluster_decision {
        label="";
        style=invis;
        margin=0;

        normal [label="Normal\n(long path = hard\nto isolate)", fillcolor="#C8E6C9", color="#2E7D32", width=2.0];
        anomaly [label="Anomaly\n(short path = easy\nto isolate)", fillcolor="#FFCDD2", color="#C62828", width=2.0];
    }

    // Layout
    title -> input [style=invis];

    input -> ss1;
    input -> ss2;
    input -> ssdots [style=invis];
    input -> ssN;

    ss1 -> it1;
    ss2 -> it2;
    ssdots -> itdots [style=invis];
    ssN -> itN;

    it1 -> pl1;
    it2 -> pl2;
    itdots -> pldots [style=invis];
    itN -> plN;

    pl1 -> agg;
    pl2 -> agg;
    pldots -> agg [style=invis];
    plN -> agg;

    agg -> score;

    score -> normal [label="score < threshold", fontcolor="#2E7D32", color="#2E7D32"];
    score -> anomaly [label="score ≥ threshold", fontcolor="#C62828", color="#C62828"];

    {rank=same; ss1; ss2; ssdots; ssN;}
    {rank=same; it1; it2; itdots; itN;}
    {rank=same; pl1; pl2; pldots; plN;}
    {rank=same; normal; anomaly;}
}
