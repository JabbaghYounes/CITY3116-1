digraph tech_stack {
    rankdir=TB;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.2];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.2, color="#555555"];
    nodesep=0.6;
    ranksep=0.7;
    pad=0.4;
    compound=true;

    // Title
    title [label="Implementation Framework", shape=plaintext, fillcolor=white,
           fontsize=14, fontcolor="#1565C0"];

    // IDS Components (top)
    subgraph cluster_components {
        label="IDS Components";
        labeljust=c;
        fontsize=10;
        color="#999999";
        style="dashed,rounded";
        margin=16;
        bgcolor="#FAFAFA";

        collector [label="Data Collection\npacket capture,\nflow reconstruction",
                   fillcolor="#E3F2FD", color="#1565C0", width=2.2];
        preprocess [label="Preprocessing\nfeature extraction,\nnormalisation, SMOTE",
                    fillcolor="#FFF3E0", color="#E65100", width=2.2];
        rules [label="Rule Engine\nModbus validation,\nregister whitelisting",
               fillcolor="#E8F5E9", color="#2E7D32", width=2.2];
        rf_if [label="Random Forest +\nIsolation Forest",
               fillcolor="#E8F5E9", color="#2E7D32", width=2.0];
        cnn_lstm [label="CNN+LSTM\nDeep Learning",
                  fillcolor="#E8F5E9", color="#2E7D32", width=2.0];
        parallel [label="Parallel Training\n(16+ CPU cores)",
                  fillcolor="#F3E5F5", color="#6A1B9A", width=2.0];
    }

    // Frameworks (bottom)
    subgraph cluster_frameworks {
        label="Technologies & Libraries";
        labeljust=c;
        fontsize=10;
        color="#999999";
        style="dashed,rounded";
        margin=16;
        bgcolor="#FAFAFA";

        libpcap [label="libpcap\n(pnet crate)", fillcolor="#FFCDD2", color="#C62828", width=1.8];
        rust [label="Rust\n(ids/ workspace)", fillcolor="#FFCDD2", color="#C62828", width=1.8];
        smartcore [label="smartcore 0.3\n(Rust ML)", fillcolor="#FFCDD2", color="#C62828", width=1.8];
        tch [label="tch-rs 0.17\n(libtorch C++)\nNVIDIA GPU", fillcolor="#FFCDD2", color="#C62828", width=1.8];
        pytorch [label="Python PyTorch\n(ROCm)\nAMD GPU", fillcolor="#FFCDD2", color="#C62828", width=1.8];
        rayon [label="rayon\n(Rust parallelism)", fillcolor="#FFCDD2", color="#C62828", width=1.8];
    }

    // Edges: components → frameworks
    collector -> libpcap [color="#1565C0"];
    preprocess -> rust [color="#E65100"];
    rules -> rust [color="#2E7D32"];
    rf_if -> smartcore [color="#2E7D32"];
    cnn_lstm -> tch [color="#2E7D32", label="NVIDIA"];
    cnn_lstm -> pytorch [color="#2E7D32", label="AMD"];
    parallel -> rayon [color="#6A1B9A"];

    // Flow between components
    collector -> preprocess [style=dashed, color="#BBBBBB"];
    preprocess -> rules [style=dashed, color="#BBBBBB"];
    preprocess -> rf_if [style=dashed, color="#BBBBBB"];
    preprocess -> cnn_lstm [style=dashed, color="#BBBBBB"];

    // Layout
    title -> collector [style=invis];

    {rank=same; collector; preprocess; rules;}
    {rank=same; rf_if; cnn_lstm; parallel;}
    {rank=same; libpcap; rust; smartcore; tch; pytorch; rayon;}
}
