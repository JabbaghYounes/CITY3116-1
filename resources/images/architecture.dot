digraph architecture {
    rankdir=TB;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    nodesep=0.6;
    ranksep=0.7;
    pad=0.4;

    // Level 3 — PC
    subgraph cluster_level3 {
        label="Level 3 — Supervision";
        labeljust=l;
        fontsize=10;
        color="#999999";
        style="dashed,rounded";
        margin=16;

        pc [label="PC / Laptop\n─────────────────\nIDS Engine (ids/)\nSCADA + Wireshark\nAttack Framework", fillcolor="#E8F4FD", color="#2196F3", width=3.0];
    }

    // Level 2 — Network
    subgraph cluster_level2 {
        label="Level 2 — Plant Network";
        labeljust=l;
        fontsize=10;
        color="#999999";
        style="dashed,rounded";
        margin=16;

        switch [label="TP-Link LS1005G\nGigabit Switch", fillcolor="#FFF3E0", color="#FF9800", shape=box, width=2.5];
    }

    // Level 1 — Controllers
    subgraph cluster_level1 {
        label="Level 1 — Controllers";
        labeljust=l;
        fontsize=10;
        color="#999999";
        style="dashed,rounded";
        margin=16;

        plc1 [label="PLC 1 — Process Controller\n──────────────────────\nArduino Mega 2560\n+ W5500 Ethernet\n192.168.1.20:502\nModbus TCP Server\nModbus RTU Master", fillcolor="#E8F5E9", color="#4CAF50", width=3.0];
        plc2 [label="PLC 2 — Sensor Node\n──────────────────────\nArduino Uno Rev3\n+ MAX485 RS-485\nModbus RTU Slave (ID 1)", fillcolor="#E8F5E9", color="#4CAF50", width=3.0];
    }

    // Level 0 — Physical
    subgraph cluster_level0 {
        label="Level 0 — Physical Process";
        labeljust=l;
        fontsize=10;
        color="#999999";
        style="dashed,rounded";
        margin=16;

        actuators [label="Actuators\n─────────────\nRelay (pump)\nServo (valve)\nBuzzer (alarm)\nLCD HMI", fillcolor="#FCE4EC", color="#E91E63", width=2.2];
        sensors [label="Sensors\n─────────────\nUltrasonic (level)\nTemperature\nSound\nMotion\nWater level", fillcolor="#F3E5F5", color="#9C27B0", width=2.2];
    }

    // Edges
    pc -> switch [label="  Ethernet\n  (Modbus TCP)", color="#2196F3"];
    switch -> plc1 [label="  Ethernet", color="#FF9800"];
    plc1 -> plc2 [label="RS-485 (Modbus RTU)\n9600 baud", color="#4CAF50", style=bold, constraint=false];
    plc1 -> actuators [label="  Digital I/O", color="#E91E63"];
    plc2 -> sensors [label="  Analog/Digital", color="#9C27B0", dir=back];
}
